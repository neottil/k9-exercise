# ── BACKEND ────────────────────────────────────────────────────────────────────

# Connessione MongoDB
MONGODB_URI=mongodb://localhost:27017/k9-exercise?replicaSet=rs0

# Porta del server backend
PORT=3001

# Modalità di login: "form" (email+password) | "token" (redirect JWT da sito esterno) | "disabled" (nessuna autenticazione)
LOGIN_TYPE=form

# Segreto condiviso tra sito esterno e app per firmare/verificare il JWT
# Generare con: openssl rand -base64 32
# Deve coincidere con K9_JWT_SECRET definito in wp-config.php
K9_JWT_SECRET=your-jwt-secret-here

# Sessione: cambiare in produzione con un valore casuale e lungo
SESSION_SECRET=your-secret-here

# ── FRONTEND ───────────────────────────────────────────────────────────────────

# Modalità di login esposta al client (deve corrispondere a LOGIN_TYPE)
VITE_LOGIN_TYPE=token

# URL del sito da cui ci si aspetta di ricevere i token JWT
VITE_LOGIN_SITE_URL=https://google.it

# Abilita la select dell'operazione (= oppure >=) nei filtri (true | false)
VITE_ENABLE_WITH_OPERATION_FILTER=false
